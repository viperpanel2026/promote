<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Viper Panel Site</title>

<style>
:root{
  color-scheme: light dark;
  --bg:#f5f7ff;
  --text:#111827;
  --muted:#4b5563;
  --card:#ffffff;
  --card-text:#1f2937;
  --border:#d1d5db;
  --primary:#4f7cff;
  --footer:#666666;
  --hero-1:#4f7cff;
  --hero-2:#7c3aed;
  --shadow:0 8px 24px rgba(0,0,0,0.06);
}

@media (prefers-color-scheme: dark){
  :root{
    --bg:#0b1024;
    --text:#f8fafc;
    --muted:#cbd5e1;
    --card:#141a3a;
    --card-text:#e5e7eb;
    --border:#374151;
    --primary:#6c8cff;
    --footer:#94a3b8;
    --hero-1:#8ab4ff;
    --hero-2:#a78bfa;
    --shadow:0 10px 28px rgba(0,0,0,0.28);
  }
}

*{
  box-sizing:border-box;
}

html{
  -webkit-text-size-adjust:100%;
}

body{
  margin:0;
  font-family:Arial, sans-serif;
  background:var(--bg);
  color:var(--text);
  transition:background .25s ease,color .25s ease;
}

.container{
  width:90%;
  max-width:1100px;
  margin:auto;
}

header{
  padding:50px 0 50px;
  text-align:center;
}

h1{
  font-size:clamp(28px,6vw,42px);
  margin:0 0 12px;
  color:var(--text);
}

.hero-text{
  background:linear-gradient(90deg,var(--hero-1),var(--hero-2));
  -webkit-background-clip:text;
  background-clip:text;
  color:transparent;
}

p{
  color:var(--muted);
  margin:0 auto 20px;
  max-width:500px;
}

.btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  margin:8px;
  padding:14px 20px;
  border-radius:10px;
  font-weight:bold;
  text-decoration:none;
  transition:transform .2s ease, background .2s ease, color .2s ease, border-color .2s ease;
  text-align:center;
  gap:8px;
}

.btn:hover{
  transform:translateY(-2px);
}

.btn-primary{
  background:var(--primary);
  color:#ffffff;
}

.btn-secondary{
  border:1px solid var(--border);
  color:var(--text);
  background:transparent;
}

.section{
  padding:50px 0;
}

/* reduce space for community section */
#community{
  padding-top:25px;
}

.section h2{
  text-align:center;
  margin:0 0 25px;
  font-size:clamp(22px,5vw,28px);
  color:var(--text);
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
  gap:16px;
}

.card{
  background:var(--card);
  color:var(--card-text);
  padding:18px;
  border-radius:14px;
  text-align:center;
  transition:transform .2s ease, background .25s ease, color .25s ease, box-shadow .25s ease;
  box-shadow:var(--shadow);
  border:1px solid var(--border);
}

.card:hover{
  transform:translateY(-4px);
}

.community-card{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:10px;
  font-weight:700;
  font-size:16px;
}

.community-card span{
  color:var(--card-text);
}

.community-card svg{
  flex:0 0 auto;
}

footer{
  text-align:center;
  padding:25px;
  font-size:14px;
  color:var(--footer);
}

.contact-form{
  max-width:600px;
  margin:20px auto 0;
  display:flex;
  flex-direction:column;
  gap:14px;
}

.contact-form label{
  font-weight:600;
  font-size:14px;
  color:var(--muted);
}

.contact-form input,
.contact-form textarea{
  width:100%;
  padding:12px;
  border-radius:8px;
  border:1px solid var(--border);
  background:var(--card);
  color:var(--text);
  font-size:14px;
}

.contact-form input:focus,
.contact-form textarea:focus{
  outline:none;
  border-color:var(--primary);
}

.contact-form button{
  margin-top:10px;
  width:fit-content;
}

@media (max-width:640px){
  .btn{
    display:flex;
    width:100%;
    max-width:320px;
    margin:10px auto;
  }

  header{
    padding:42px 0 38px;
  }
}
</style>
</head>

